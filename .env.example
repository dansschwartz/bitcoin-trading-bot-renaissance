# Renaissance Trading Bot — Environment Variables
# Copy this to .env and fill in your actual keys
# NEVER commit .env to git

# MEXC Exchange (Primary — 0% maker fee)
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# Binance Exchange (Secondary)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Optional: Bybit (disabled — 30bps fee floor makes triangular arb unprofitable)
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# Optional: KuCoin (spoke exchange for cross-exchange arb)
# KUCOIN_API_KEY=
# KUCOIN_API_SECRET=
# KUCOIN_PASSPHRASE=

# Legacy keys (main bot, not arbitrage)
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
NEWSAPI_KEY=
WHALE_ALERT_KEY=
